{
  "name": "grace",
  "version": "0.1.3",
  "private": true,
  "description": "Local-first desktop AI chat client.",
  "author": "Igor Barchuk",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "node node_modules/electron/install.js",
    "ensure:electron": "node node_modules/electron/install.js",
    "dev": "npm run ensure:electron && electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64 --x64 --publish never",
    "preview": "npm run ensure:electron && electron-vite preview",
    "smoke:provider": "node scripts/smoke-provider.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.5.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "build": {
    "appId": "com.sainquat.grace",
    "productName": "Grace",
    "asar": true,
    "afterPack": "./scripts/codesign-mac-app.mjs",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Grace ${version}",
      "artifactName": "Grace-${version}-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
