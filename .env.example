# App
APP_ENV=development
PORT=3000

# AI provider credentials. Copy to .env.local and keep real values out of git.
AI_PROVIDER=
AI_API_KEY=

# Optional live smoke test for custom OpenAI-compatible providers.
GRACE_PROVIDER_BASE_URL=
GRACE_PROVIDER_API_KEY=

# Optional deployment webhook used by .github/workflows/deploy.yml.
DEPLOY_WEBHOOK_URL=
